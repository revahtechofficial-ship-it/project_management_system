# Copy to .env (next to docker-compose.yml). `docker compose` auto-loads it.
#
# Generate a strong Vikunja secret:
#   bash:        openssl rand -hex 32
#   PowerShell:  -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })

# Postgres superuser password
POSTGRES_PASSWORD=postgres

# Vikunja
VIKUNJA_SERVICE_SECRET=CHANGE_ME_run_openssl_rand_hex_32
VIKUNJA_PUBLIC_URL=http://localhost:3456/

# Browser origin the Go backend allows (Flutter web). Used only by the `app` profile.
CORS_ORIGIN=*

# Keycloak admin console password (user: admin) at http://localhost:8088
KEYCLOAK_ADMIN_PASSWORD=admin
