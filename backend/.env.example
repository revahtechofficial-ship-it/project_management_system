# Copy to .env and adjust. Real environment variables override these.

# pgx/libpq connection string for PostgreSQL.
# Matches the revahms role/database created by deploy/postgres/init/01-databases.sql.
DATABASE_URL=postgres://revahms:revahms@localhost:5432/revahms?sslmode=disable

# Vikunja instance the BFF proxies/aggregates (no trailing slash).
VIKUNJA_BASE_URL=http://localhost:3456

# Keycloak realm issuer used to verify bearer tokens (host.docker.internal so it
# matches the issuer the browser and other containers see).
OIDC_ISSUER=http://host.docker.internal:8088/realms/revahms

# HTTP port the API listens on.
PORT=8080

# Allowed browser origin for the Flutter web client.
# Use "*" for local dev; set the real origin (e.g. https://app.example.com) in prod.
CORS_ORIGIN=*

# --- Custom auth (email/password + OTP) ---
# Secret that signs app session JWTs. CHANGE THIS (openssl rand -hex 32).
JWT_SECRET=dev-insecure-change-me
APP_NAME=Revah Management System

# SMTP for sending 6-digit OTP emails. If SMTP_HOST/SMTP_FROM are blank, the
# backend logs the OTP to its console instead (handy for local dev).
# Gmail example: host smtp.gmail.com, port 587, user+from = your gmail,
# pass = a 16-char Google "App Password" (not your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
