# Copy to .env and adjust. Real environment variables override these.

# pgx/libpq connection string for PostgreSQL.
# Matches the nexax role/database created by deploy/postgres/init/01-databases.sql.
DATABASE_URL=postgres://nexax:nexax@localhost:5432/nexax?sslmode=disable

# Vikunja instance the BFF proxies/aggregates (no trailing slash).
VIKUNJA_BASE_URL=http://localhost:3456

# Keycloak realm issuer used to verify bearer tokens (host.docker.internal so it
# matches the issuer the browser and other containers see).
OIDC_ISSUER=http://host.docker.internal:8088/realms/nexax

# HTTP port the API listens on.
PORT=8080

# Allowed browser origin for the Flutter web client.
# Use "*" for local dev; set the real origin (e.g. https://app.example.com) in prod.
CORS_ORIGIN=*
